<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Debug-only. Allows the debugger and test runner to attach to the
	  Developer ID-signed build. Release builds do not include this (a build
	  carrying get-task-allow cannot be notarized).
	-->
	<key>com.apple.security.get-task-allow</key>
	<true/>
</dict>
</plist>
